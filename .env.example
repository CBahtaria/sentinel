# Sentinel environment variables — copy to .env and fill in values.
# Never commit .env with real values.

# ── Database ────────────────────────────────────────────────────────────────
SENTINEL_DB_HOST=sentinel-mysql
SENTINEL_DB_PORT=3306
SENTINEL_DB_NAME=uedf_sentinel
SENTINEL_DB_USER=sentinel
SENTINEL_DB_PASS=changeme_strong_password

# ── Authentication ──────────────────────────────────────────────────────────
# 32-byte random hex: openssl rand -hex 32
SENTINEL_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
SENTINEL_CORS_ORIGINS=http://localhost,http://localhost:8000,http://localhost:3000

# ── WebSocket ───────────────────────────────────────────────────────────────
SENTINEL_WS_PORT=8090

# ── UAV Stack Bridge ────────────────────────────────────────────────────────
# Set by the Docker Compose network — bridge reads from NATS, writes to MySQL.
UAV_NATS_URL=nats://nats:4222
